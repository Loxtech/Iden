@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider _authenticationStateProvider

<div class="page" style="min-height:100vh; display:flex; flex-direction:column;">
    <main style="display:flex; flex-direction:column; flex:1;">

        <!-- Purple Navbar -->
        <nav style="background-color:#6c3fc5; padding: 0.6rem 1.5rem; display:flex; align-items:center;">
            <!-- Brand -->
            <a href="/" style="color:white; font-weight:bold; font-size:1.1rem; text-decoration:none; margin-right:2rem;">
                Trauma Center
            </a>

            <!-- Left links -->
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <NavLink href="" Match="NavLinkMatch.All"
                         style="color:white; text-decoration:none; padding:0.3rem 0.8rem; border-radius:4px;"
                         activeClass="active-nav">
                    Home
                </NavLink>

                <AuthorizeView>
                    <Authorized>
                        <NavLink href="Aktiviteter"
                                 style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                                 activeClass="active-nav">
                            Aktiviteter
                        </NavLink>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink href="Aktiviteter"
                                 style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                                 activeClass="active-nav">
                            Aktiviteter
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>

                @if (_isAdmin)
                {
                    <NavLink href="/addroles"
                             style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                             activeClass="active-nav">
                        Admin
                    </NavLink>
                }
            </div>

            <!-- Right links -->
            <div style="margin-left:auto; display:flex; align-items:center; gap:0.25rem;">
                <AuthorizeView>
                    <Authorized>
                        <NavLink href="Account/Manage"
                                 style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                                 activeClass="active-nav">
                            @context.User.Identity?.Name
                        </NavLink>
                        <form action="Account/Logout" method="post" style="margin:0;">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit"
                                    style="background:none; border:none; color:white; cursor:pointer; padding:0.3rem 0.8rem;">
                                Logout
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink href="Account/Register"
                                 style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                                 activeClass="active-nav">
                            Register
                        </NavLink>
                        <NavLink href="Account/Login"
                                 style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                                 activeClass="active-nav">
                            Login
                        </NavLink>
                        <div style="width:1px; height:14px; background-color:rgba(255,255,255,0.4);"></div>
                        <NavLink href="Account/RegisterPasswordless"
                                 style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                                 activeClass="active-nav">
                            Register (Passwordless)
                        </NavLink>
                        <NavLink href="Account/LoginPasswordless"
                                 style="color:white; text-decoration:none; padding:0.3rem 0.8rem;"
                                 activeClass="active-nav">
                            Login (Passwordless)
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </nav>

        <!-- Page content -->
        <article style="flex:1; padding: 0 1.5rem;">
            @Body
        </article>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Albertslund kommune
            </div>
        </footer>
    </main>
</div>

<style>
    .active-nav {
        background-color: rgba(255,255,255,0.2);
        border-radius: 4px;
    }
</style>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string? currentUrl;
    private bool _isAuthenticated;
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var stateProvider = await _authenticationStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = stateProvider.User.Identity?.IsAuthenticated ?? false;
        _isAdmin = stateProvider.User.IsInRole("Admin");

        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
