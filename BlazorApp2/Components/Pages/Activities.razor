@page "/aktiviteter"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using BlazorApp2.Data

@attribute [Authorize]

@inject UserManager<ApplicationUser> UserManager
@inject ILogger<Auth> Logger

<PageTitle>Terapeutiske aktiviteter</PageTitle>

<div class="container py-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5 fw-bold">Terapeutiske aktiviteter</h1>
            <p class="lead text-muted">Gennemse og tilmeld dig tilgængelige traumerestitutionsprogrammer</p>
        </div>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="card-title mb-0">Kognitiv Adfærdsterapi (CBT)</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Tidsplan:</strong> Mandag og Onsdag, 10:00</p>
                            <p><strong>Varighed:</strong> 8 uger</p>
                            <p><strong>Deltagere:</strong> 12/20</p>
                            <p class="text-muted">Evidensbaseret terapi til at bearbejde trauma og udvikle mestringsstrategier.</p>
                        </div>
                        <div class="card-footer bg-light">
                            @if (registeredCBT)
                            {
                                <button class="btn btn-sm btn-success" @onclick="@(() => registeredCBT = false)">Tilmeldt!</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-primary" @onclick="@(() => registeredCBT = true)">Tilmeld</button>
                            }
                            <span class="badge bg-success ms-2">Ledig</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="card-title mb-0">Mindfulness og Meditation</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Tidsplan:</strong> Tirsdag og Torsdag, 14:00</p>
                            <p><strong>Varighed:</strong> 6 uger</p>
                            <p><strong>Deltagere:</strong> 15/15</p>
                            <p class="text-muted">Stressreduktion og følelsesmæssig regulering gennem guidede mindfulnessøvelser.</p>
                        </div>
                        <div class="card-footer bg-light">
                            <button class="btn btn-sm btn-secondary" disabled>Tilmeld</button>
                            <span class="badge bg-danger ms-2">Fuldt</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="card-title mb-0">Fysisk Wellness og Træning</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Tidsplan:</strong> Fredag, 11:00</p>
                            <p><strong>Varighed:</strong> Løbende</p>
                            <p><strong>Deltagere:</strong> 8/25</p>
                            <p class="text-muted">Lavintensitive træningsprogrammer tilpasset traumerestitution og generelt velvære.</p>
                        </div>
                        <div class="card-footer bg-light">
                            @if (registeredExercise)
                            {
                                <button class="btn btn-sm btn-success" @onclick="@(() => registeredExercise = false)">Tilmeldt!</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-primary" @onclick="@(() => registeredExercise = true)">Tilmeld</button>
                            }
                            <span class="badge bg-success ms-2">Ledig</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="card-title mb-0">Gruppestøtte og Peer-terapi</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Tidsplan:</strong> Onsdag, 15:00</p>
                            <p><strong>Varighed:</strong> 10 uger</p>
                            <p><strong>Deltagere:</strong> 10/15</p>
                            <p class="text-muted">Forbind dig med andre på lignende genopretningsrejser i en sikker, fortrolig ramme.</p>
                        </div>
                        <div class="card-footer bg-light">
                            @if (registeredGroup)
                            {
                                <button class="btn btn-sm btn-success" @onclick="@(() => registeredGroup = false)">Tilmeldt!</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-primary" @onclick="@(() => registeredGroup = true)">Tilmeld</button>
                            }
                            <span class="badge bg-success ms-2">Ledig</span>
                        </div>
                    </div>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    private bool registeredCBT = false;
    private bool registeredExercise = false;
    private bool registeredGroup = false;
}
