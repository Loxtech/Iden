@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Traumecenter - Hjem</PageTitle>

<!-- Hero Section -->
<div class="container-fluid py-5">
    <div class="row align-items-center px-5">
        <!-- Left side -->
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold mb-3">Traumecenter</h1>
            <p class="lead text-muted mb-4">
                Velkommen til Albertslund Kommunes traumecenter. Vi tilbyder
                professionel støtte og terapeutiske aktiviteter til borgere i genoptræning
                efter traumer.
            </p>
            <AuthorizeView>
                <NotAuthorized>
                    <div class="d-flex gap-2">
                        <a href="/Account/Register" class="btn btn-primary btn-lg px-4">Kom i gang</a>
                        <a href="/Account/Login" class="btn btn-outline-primary btn-lg px-4">Log ind</a>
                    </div>
                </NotAuthorized>
                <Authorized>
                    <div class="d-flex gap-2">
                        <a href="/aktiviteter" class="btn btn-primary btn-lg px-4">Se aktiviteter</a>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <!-- Right side card -->
        <div class="col-lg-5 offset-lg-1">
            <div class="card shadow-sm border-0 p-4">
                <h5 class="fw-semibold mb-3">Om vores center</h5>
                <ul class="list-unstyled mb-0">
                    <li class="d-flex align-items-start mb-3">
                        <span class="badge bg-success me-2 mt-1">✓</span>
                        <span><strong>Ekspertpleje:</strong> Professionel terapeutisk støtte</span>
                    </li>
                    <li class="d-flex align-items-start mb-3">
                        <span class="badge bg-success me-2 mt-1">✓</span>
                        <span><strong>Sikker platform:</strong> HTTPS-krypteret kommunikation</span>
                    </li>
                    <li class="d-flex align-items-start mb-3">
                        <span class="badge bg-success me-2 mt-1">✓</span>
                        <span><strong>Privatliv først:</strong> Beskyttede personoplysninger (CPR-numre)</span>
                    </li>
                    <li class="d-flex align-items-start mb-3">
                        <span class="badge bg-success me-2 mt-1">✓</span>
                        <span><strong>Flere aktiviteter:</strong> Forskellige traumeterapiprogrammer</span>
                    </li>
                    <li class="d-flex align-items-start">
                        <span class="badge bg-success me-2 mt-1">✓</span>
                        <span><strong>Adgang døgnet rundt:</strong> Administrer din profil når som helst</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<hr class="mx-5" />

<!-- Feature cards -->
<div class="container-fluid py-4 px-5">
    <div class="row text-center">
        <div class="col-md-4 px-4">
            <div class="card border-0 shadow-sm py-4 px-3 h-100">
                <div class="fs-1 mb-3">📋</div>
                <h6 class="fw-semibold">Nem registrering</h6>
                <p class="text-muted small mb-0">
                    Opret din profil med sikker adgangskodebeskyttelse og CPR-kryptering.
                </p>
            </div>
        </div>
        <div class="col-md-4 px-4">
            <div class="card border-0 shadow-sm py-4 px-3 h-100">
                <div class="fs-1 mb-3">🛡️</div>
                <h6 class="fw-semibold">Sikker & Privat</h6>
                <p class="text-muted small mb-0">
                    Dine følsomme oplysninger er beskyttet med industristandard kryptering.
                </p>
            </div>
        </div>
        <div class="col-md-4 px-4">
            <div class="card border-0 shadow-sm py-4 px-3 h-100">
                <div class="fs-1 mb-3">🎯</div>
                <h6 class="fw-semibold">Følg din udvikling</h6>
                <p class="text-muted small mb-0">
                    Overvåg din deltagelse i terapeutiske aktiviteter og din genopretningsrejse.
                </p>
            </div>
        </div>
    </div>
</div>
